<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Theme -->
    <style name="Base.Theme.QuinielaApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
    </style>

    <style name="Theme.QuinielaApp" parent="Base.Theme.QuinielaApp" />

    <!-- Splash Theme: shows QGol logo centered on background -->
    <style name="Theme.QGol.Splash" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_logo</item>
    </style>

    <!-- ============================================ -->
    <!-- BUTTONS -->
    <!-- ============================================ -->
    
    <!-- Primary Button - Full width, rounded, elevated -->
    <style name="Widget.Quiniela.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">56dp</item>
        <item name="elevation">4dp</item>
    </style>
    
    <!-- Secondary Button - Outline style -->
    <style name="Widget.Quiniela.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/border_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">56dp</item>
    </style>
    
    <!-- Text Button -->
    <style name="Widget.Quiniela.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- ============================================ -->
    <!-- INPUT FIELDS -->
    <!-- ============================================ -->
    
    <!-- Filled Input Field -->
    <style name="Widget.Quiniela.TextInputLayout.Filled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxBackgroundColor">@color/input_surface</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="startIconTint">@color/text_secondary</item>
    </style>
    
    <!-- Input EditText -->
    <style name="Widget.Quiniela.TextInputEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- ============================================ -->
    <!-- CARDS -->
    <!-- ============================================ -->
    
    <!-- Elevated Card - Premium floating look -->
    <style name="Widget.Quiniela.Card.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>
    
    <!-- Outlined Card -->
    <style name="Widget.Quiniela.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">20dp</item>
        <item name="strokeColor">@color/border_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <!-- ============================================ -->
    <!-- TYPOGRAPHY -->
    <!-- ============================================ -->
    
    <!-- Hero Title - Large bold -->
    <style name="TextAppearance.Quiniela.Hero" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">36sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- Screen Title -->
    <style name="TextAppearance.Quiniela.ScreenTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- Section Header -->
    <style name="TextAppearance.Quiniela.SectionHeader" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- Body Text -->
    <style name="TextAppearance.Quiniela.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- Body Secondary -->
    <style name="TextAppearance.Quiniela.Body.Secondary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- Caption -->
    <style name="TextAppearance.Quiniela.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Headline 6 -->
    <style name="TextAppearance.App.Headline6" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ============================================ -->
    <!-- BADGES & TAGS -->
    <!-- ============================================ -->
    
    <!-- Success Badge -->
    <style name="Widget.Quiniela.Badge.Success" parent="">
        <item name="android:background">@drawable/bg_badge_success</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">4dp</item>
    </style>
    
    <!-- Primary Badge -->
    <style name="Widget.Quiniela.Badge.Primary" parent="">
        <item name="android:background">@drawable/bg_badge_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">4dp</item>
    </style>
</resources>