<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/cancha_futbol"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="false"
        android:focusable="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:titleTextColor="#FFFFFF"
            app:menu="@menu/dashboard_menu"
            app:titleTextAppearance="@style/TextAppearance.App.Headline6"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- INICIO TAB -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scrollInicio"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:paddingHorizontal="20dp"
                        android:visibility="gone" />

                    <!-- Próximo partido (compacto) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardProximoPartido"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="#4D1A1A2E"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#29FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="⚽ Próximo partido"
                                    android:textSize="12sp"
                                    android:textColor="#FFFFFF"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvProximoQuiniela"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="9sp"
                                    android:textColor="#66FFFFFF"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:layout_marginBottom="4dp">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <ImageView
                                        android:id="@+id/ivProximoLocal"
                                        android:layout_width="24dp"
                                        android:layout_height="16dp"
                                        android:scaleType="fitCenter"
                                        android:contentDescription="Bandera local"/>

                                    <TextView
                                        android:id="@+id/tvProximoLocal"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="11sp"
                                        android:textColor="#FFFFFF"
                                        android:textStyle="bold"
                                        android:layout_marginTop="2dp"
                                        android:gravity="center"/>
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="vs"
                                    android:textSize="14sp"
                                    android:textColor="#44FFFFFF"
                                    android:textStyle="bold"
                                    android:layout_marginHorizontal="8dp"/>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <ImageView
                                        android:id="@+id/ivProximoVisitante"
                                        android:layout_width="24dp"
                                        android:layout_height="16dp"
                                        android:scaleType="fitCenter"
                                        android:contentDescription="Bandera visitante"/>

                                    <TextView
                                        android:id="@+id/tvProximoVisitante"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="11sp"
                                        android:textColor="#FFFFFF"
                                        android:textStyle="bold"
                                        android:layout_marginTop="2dp"
                                        android:gravity="center"/>
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/layoutCuentaRegresiva"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:layout_marginBottom="6dp">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:layout_marginHorizontal="8dp">
                                    <TextView android:id="@+id/tvCountdownDias" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textSize="16sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Días" android:textSize="7sp" android:textColor="#66FFFFFF" android:textStyle="bold"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="8dp">
                                    <TextView android:id="@+id/tvCountdownHoras" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textSize="16sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Horas" android:textSize="7sp" android:textColor="#66FFFFFF" android:textStyle="bold"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="8dp">
                                    <TextView android:id="@+id/tvCountdownMinutos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textSize="16sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Min" android:textSize="7sp" android:textColor="#66FFFFFF" android:textStyle="bold"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="8dp">
                                    <TextView android:id="@+id/tvCountdownSegundos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textSize="16sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seg" android:textSize="7sp" android:textColor="#66FFFFFF" android:textStyle="bold"/>
                                </LinearLayout>
                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPronosticarProximo"
                                android:layout_width="match_parent"
                                android:layout_height="36dp"
                                android:text="Pronosticar"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                app:backgroundTint="#0D5BFF"
                                app:cornerRadius="12dp"
                                app:elevation="2dp"/>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card Sistema de puntos -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPuntosInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        app:cardBackgroundColor="#4D1A1A2E"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#29FFFFFF"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="🏆"
                                android:textSize="16sp"
                                android:gravity="center"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sistema de puntos"
                                    android:textSize="13sp"
                                    android:textColor="#FFFFFF"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Aprende cómo sumar más puntos"
                                    android:textSize="10sp"
                                    android:textColor="#88FFFFFF"
                                    android:layout_marginTop="1dp"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="24dp"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Ver reglas"
                                android:textSize="10sp"
                                android:textColor="#0D5BFF"
                                android:textStyle="bold"
                                android:background="@drawable/bg_segmented_control"
                                android:clickable="false"
                                android:focusable="false"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- En Vivo compacto + Mis Quinielas -->
                    <TextView
                        android:id="@+id/tvSectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="8dp" />

                    <!-- En Vivo compacto -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPartidosEnVivo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="#B01A1A2E"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#33FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <LinearLayout
                                android:id="@+id/layoutLiveSectionHeader"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <View android:layout_width="6dp" android:layout_height="6dp" android:background="@drawable/bg_live_indicator" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="En Vivo"
                                    android:textColor="#FF4D4D"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginStart="4dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvLiveHeader"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:layout_marginBottom="2dp" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvPartidosEnVivo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Quinielas List -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvQuinielas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:paddingBottom="16dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_quiniela" />

                    <!-- Empty State -->
                    <LinearLayout
                        android:id="@+id/tvEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="gone"
                        android:paddingVertical="24dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No tienes quinielas aún"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:alpha="0.9" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¡Crea una o únete para empezar!"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:alpha="0.7"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- EN VIVO TAB -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scrollEnVivo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resultados y En Vivo"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvEnVivoFull"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </FrameLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E01A1A2E"
            app:itemIconTint="#88FFFFFF"
            app:itemTextColor="#FFFFFF"
            app:menu="@menu/bottom_nav_menu" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnCrearQuiniela"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="72dp"
        android:text="Crear"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="#FFFFFF"
        app:backgroundTint="#0D5BFF"
        app:elevation="8dp"
        app:fabSize="normal"
        app:cornerRadius="20dp" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnUnirseQuiniela"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="Unirse QR"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:icon="@android:drawable/ic_menu_camera"
        app:iconTint="#FFFFFF"
        app:backgroundTint="#00B86B"
        app:elevation="8dp"
        app:fabSize="normal"
        app:cornerRadius="20dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#FFFFFF" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
