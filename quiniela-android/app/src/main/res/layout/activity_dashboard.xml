<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/cancha_futbol" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="false"
        android:focusable="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:menu="@menu/dashboard_menu"
            app:popupTheme="@style/Widget.Quiniela.Toolbar.PopupMenu"
            app:titleTextAppearance="@style/TextAppearance.App.Headline6"
            app:titleTextColor="#FFFFFF" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- INICIO TAB -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scrollInicio"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <!-- Card Sistema de puntos -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPuntosInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        style="@style/Widget.Quiniela.Card.GlassSmall">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:gravity="center"
                                android:text="🏆"
                                android:textSize="16sp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sistema de puntos"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="1dp"
                                    android:text="Aprende cómo sumar más puntos"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_segmented_control"
                                android:clickable="false"
                                android:focusable="false"
                                android:gravity="center"
                                android:paddingHorizontal="10dp"
                                android:text="Ver reglas"
                                android:textColor="#2563EB"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvSectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:text="Mis Quinielas"
                        android:textAppearance="@style/TextAppearance.Quiniela.SectionTitle" />

                    <!-- Quinielas List -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvQuinielas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingBottom="16dp"
                        tools:listitem="@layout/item_quiniela" />

                    <!-- Empty State -->
                    <LinearLayout
                        android:id="@+id/tvEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="24dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.9"
                            android:text="No tienes quinielas aún"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:alpha="0.7"
                            android:text="¡Crea una o únete para empezar!"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- EN VIVO TAB -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scrollEnVivo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Resultados y En Vivo"
                        android:textAppearance="@style/TextAppearance.Quiniela.SectionTitle" />

                    <!-- Próximo partido -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardProximoPartido"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"
                        style="@style/Widget.Quiniela.Card.GlassSmall">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:layout_marginBottom="4dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="⚽ Próximo partido"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvProximoQuiniela"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="9sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:layout_marginBottom="4dp">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:id="@+id/ivProximoLocal"
                                        android:layout_width="28dp"
                                        android:layout_height="20dp"
                                        android:scaleType="fitCenter"
                                        android:contentDescription="Bandera local" />

                                    <TextView
                                        android:id="@+id/tvProximoLocal"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:gravity="center"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginHorizontal="12dp"
                                    android:text="VS"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageView
                                        android:id="@+id/ivProximoVisitante"
                                        android:layout_width="28dp"
                                        android:layout_height="20dp"
                                        android:scaleType="fitCenter"
                                        android:contentDescription="Bandera visitante" />

                                    <TextView
                                        android:id="@+id/tvProximoVisitante"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:gravity="center"
                                        android:textColor="#FFFFFF"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/layoutCuentaRegresiva"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:layout_marginBottom="6dp">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:layout_marginHorizontal="8dp">
                                    <TextView android:id="@+id/tvCountdownDias" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Días" android:textColor="@color/text_secondary" android:textSize="8sp" android:textStyle="bold" />
                                </LinearLayout>
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:layout_marginHorizontal="8dp">
                                    <TextView android:id="@+id/tvCountdownHoras" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Horas" android:textColor="@color/text_secondary" android:textSize="8sp" android:textStyle="bold" />
                                </LinearLayout>
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:layout_marginHorizontal="8dp">
                                    <TextView android:id="@+id/tvCountdownMinutos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Min" android:textColor="@color/text_secondary" android:textSize="8sp" android:textStyle="bold" />
                                </LinearLayout>
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:layout_marginHorizontal="8dp">
                                    <TextView android:id="@+id/tvCountdownSegundos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seg" android:textColor="@color/text_secondary" android:textSize="8sp" android:textStyle="bold" />
                                </LinearLayout>
                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPronosticarProximo"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="Pronosticar"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                app:backgroundTint="@color/primary"
                                app:cornerRadius="16dp"
                                app:elevation="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- En Vivo List -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvEnVivoFull"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- ELIMINATORIAS TAB -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scrollEliminatorias"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvEliminatoriasInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvBracket"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <LinearLayout
                        android:id="@+id/layoutEliminatoriasEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="32dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆"
                            android:textSize="48sp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No hay eliminatorias disponibles"
                            android:textColor="@color/text_secondary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Los cruces se generarán cuando la fase de grupos finalice."
                            android:textColor="@color/text_hint"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </FrameLayout>

        <!-- ============================================ -->
        <!-- SCOREBOARD BOTTOM NAVIGATION               -->
        <!-- ============================================ -->
        <FrameLayout
            android:id="@+id/scoreboardContainer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:layout_marginBottom="12dp"
            android:clickable="false"
            android:focusable="false"
            android:elevation="12dp">

            <!-- Main scoreboard background with diagonal edges -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_scoreboard_container"
                android:clickable="false"
                android:focusable="false" />

            <!-- LED accent - left top short -->
            <View
                android:layout_width="2dp"
                android:layout_height="14dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="14dp"
                android:layout_marginTop="4dp"
                android:background="#992563EB"
                android:rotation="-15" />

            <!-- LED accent - left bottom long -->
            <View
                android:layout_width="2dp"
                android:layout_height="20dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="18dp"
                android:layout_marginBottom="2dp"
                android:background="#992563EB"
                android:rotation="-15" />

            <!-- LED accent - right top short -->
            <View
                android:layout_width="2dp"
                android:layout_height="14dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="14dp"
                android:layout_marginTop="4dp"
                android:background="#992563EB"
                android:rotation="15" />

            <!-- LED accent - right bottom long -->
            <View
                android:layout_width="2dp"
                android:layout_height="20dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="18dp"
                android:layout_marginBottom="2dp"
                android:background="#992563EB"
                android:rotation="15" />

            <!-- Tabs container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingLeft="28dp"
                android:paddingRight="28dp">

                <!-- TAB: Inicio -->
                <FrameLayout
                    android:id="@+id/tabInicio"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <!-- Blue glow behind icon -->
                    <View
                        android:id="@+id/glowInicio"
                        android:layout_width="40dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="4dp"
                        android:alpha="0"
                        android:background="@drawable/bg_glow_active" />

                    <!-- Content -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/ivTabInicio"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_nav_home"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvTabInicio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inicio"
                            android:textColor="#8A8AA5"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Blue indicator line -->
                    <View
                        android:id="@+id/lineInicio"
                        android:layout_width="32dp"
                        android:layout_height="2dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="4dp"
                        android:alpha="0"
                        android:background="#2563EB" />
                </FrameLayout>

                <!-- TAB: En Vivo -->
                <FrameLayout
                    android:id="@+id/tabEnVivo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <View
                        android:id="@+id/glowEnVivo"
                        android:layout_width="40dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="4dp"
                        android:alpha="0"
                        android:background="@drawable/bg_glow_active" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/ivTabEnVivo"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_nav_live"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvTabEnVivo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="En Vivo"
                            android:textColor="#8A8AA5"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/lineEnVivo"
                        android:layout_width="32dp"
                        android:layout_height="2dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="4dp"
                        android:alpha="0"
                        android:background="#2563EB" />
                </FrameLayout>

                <!-- TAB: Eliminatorias -->
                <FrameLayout
                    android:id="@+id/tabEliminatorias"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <View
                        android:id="@+id/glowEliminatorias"
                        android:layout_width="40dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="4dp"
                        android:alpha="0"
                        android:background="@drawable/bg_glow_active" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/ivTabEliminatorias"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_nav_bracket"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvTabEliminatorias"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Eliminatorias"
                            android:textColor="#8A8AA5"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/lineEliminatorias"
                        android:layout_width="32dp"
                        android:layout_height="2dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="4dp"
                        android:alpha="0"
                        android:background="#2563EB" />
                </FrameLayout>

            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnCrearQuiniela"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="122dp"
        android:text="Crear"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        app:backgroundTint="@color/primary"
        app:cornerRadius="12dp"
        app:elevation="4dp"
        app:icon="@android:drawable/ic_input_add"
        app:iconSize="14dp"
        app:iconTint="#FFFFFF" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnUnirseQuiniela"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="72dp"
        android:text="Unirse QR"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        app:backgroundTint="@color/success"
        app:cornerRadius="12dp"
        app:elevation="4dp"
        app:icon="@android:drawable/ic_menu_camera"
        app:iconSize="14dp"
        app:iconTint="#FFFFFF" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
