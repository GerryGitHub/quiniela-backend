<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Hero Section - 44% of screen -->
    <FrameLayout
        android:id="@+id/heroBackground"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fitsSystemWindows="true"
        app:layout_constraintHeight_percent="0.44"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Gradient Background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_login_new" />

        <!-- Geometric Pattern Overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_pattern_refined" />

        <!-- Decorative diagonal lines -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_diagonals" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="24dp">

            <!-- Left Content -->
            <LinearLayout
                android:id="@+id/heroContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="100dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QGol"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="-0.03"
                    android:shadowColor="#000000"
                    android:shadowDx="0"
                    android:shadowDy="3"
                    android:shadowRadius="6" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recuperar acceso"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:alpha="0.95"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Hero Ball -->
            <ImageView
                android:layout_width="400dp"
                android:layout_height="400dp"
                android:src="@drawable/login_ball_hero"
                android:scaleType="fitCenter"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="-80dp"
                android:layout_marginTop="-60dp" />

        </RelativeLayout>

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="center"
            android:tint="#FFFFFF"
            android:layout_margin="16dp"
            android:contentDescription="Volver" />

    </FrameLayout>

    <!-- Floating White Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/heroBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-40dp"
        android:layout_marginHorizontal="16dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Olvidaste tu contraseña?"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="8dp" />

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ingresa tu correo y te enviaremos un código de verificación."
                    android:textSize="14sp"
                    android:textColor="#6B7280"
                    android:lineSpacingExtra="4sp"
                    android:layout_marginBottom="32dp" />

                <!-- Email Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="24dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxBackgroundColor="#F8FAFC"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeColor="#E2E8F0"
                    app:hintTextColor="#94A3B8"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="#6B7280">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Correo electrónico"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Inline Error -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layoutError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFF0F0"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:layout_marginEnd="10dp"
                            android:tint="#DC2626" />

                        <TextView
                            android:id="@+id/tvError"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:textColor="#DC2626"
                            android:lineSpacingExtra="2sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Inline Success Message -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layoutSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F0FDF4"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvSuccess"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:textColor="#16A34A"
                            android:lineSpacingExtra="2sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Send Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSend"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Enviar código"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#0D5BFF"
                    app:cornerRadius="16dp"
                    app:elevation="4dp"
                    app:rippleColor="#0847CC" />

                <!-- Reset Fields (shown after code is sent) -->
                <LinearLayout
                    android:id="@+id/layoutResetFields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Email display -->
                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#0D5BFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp" />

                    <!-- Verification Code Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCode"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxBackgroundColor="#F8FAFC"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeColor="#E2E8F0"
                        app:hintTextColor="#94A3B8"
                        app:startIconDrawable="@android:drawable/ic_menu_manage"
                        app:startIconTint="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Código de verificación"
                            android:textColor="#111827"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:letterSpacing="0.2"
                            android:inputType="number"
                            android:maxLength="6" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- New Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNewPassword"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxBackgroundColor="#F8FAFC"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeColor="#E2E8F0"
                        app:hintTextColor="#94A3B8"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="#6B7280"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:startIconTint="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nueva contraseña"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilConfirmPassword"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="24dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxBackgroundColor="#F8FAFC"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeColor="#E2E8F0"
                        app:hintTextColor="#94A3B8"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="#6B7280"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:startIconTint="#6B7280">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Confirmar contraseña"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Reset Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReset"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Restablecer contraseña"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#0D5BFF"
                        app:cornerRadius="16dp"
                        app:elevation="4dp"
                        app:rippleColor="#0847CC" />
                </LinearLayout>

                <!-- Back to Login -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="24dp">

                    <TextView
                        android:id="@+id/btnBackToLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Volver a inicio de sesión"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#0D5BFF"
                        android:padding="4dp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:visibility="gone"
                    android:indeterminateTint="#0D5BFF" />

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
