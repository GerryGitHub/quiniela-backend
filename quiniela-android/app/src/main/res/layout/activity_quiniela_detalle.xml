<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Full-screen stadium background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/cancha_futbol"
        android:scaleType="centerCrop" />

    <!-- Scrim overlay for legibility -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="false"
        android:focusable="false" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Transparent Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="24dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:titleTextColor="#FFFFFF"
                app:navigationIcon="@drawable/ic_back_white"
                app:titleTextAppearance="@style/TextAppearance.App.Headline6"/>

        </FrameLayout>

        <!-- Summary text -->
        <TextView
            android:id="@+id/tvInfoQuiniela"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#99FFFFFF"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp"
            tools:text="10 partidos - Tu puntuacion: 12 pts"/>

        <!-- Segmented Control Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_segmented_control"
            app:tabIndicatorHeight="0dp"
            app:tabSelectedTextColor="#FFFFFF"
            app:tabTextColor="#99FFFFFF"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabRippleColor="@android:color/transparent"
            android:padding="4dp">

            <com.google.android.material.tabs.TabItem
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Mis Pronósticos"/>

            <com.google.android.material.tabs.TabItem
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Posiciones"/>

        </com.google.android.material.tabs.TabLayout>

        <!-- Content Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/layoutPronosticos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPartidos"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:clipToPadding="false"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGuardarPronosticos"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="16dp"
                    android:text="Guardar Pronósticos"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:backgroundTint="#0D5BFF"
                    app:cornerRadius="20dp"
                    app:elevation="8dp"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvParticipantes"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp"
                android:paddingTop="4dp"
                android:clipToPadding="false"
                android:visibility="gone"/>

        </FrameLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#FFFFFF"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
