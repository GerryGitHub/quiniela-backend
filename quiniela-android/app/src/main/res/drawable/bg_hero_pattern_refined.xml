<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Green accent diagonal -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#0000B86B"
                android:endColor="#1500B86B"
                android:angle="45"/>
        </shape>
    </item>
    <!-- Red accent diagonal -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#15FF4D4D"
                android:endColor="#00000000"
                android:angle="135"/>
        </shape>
    </item>
    <!-- Subtle top light -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#08FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"/>
        </shape>
    </item>
    <!-- Soft radial from center-right -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:centerX="1.0"
                android:centerY="0.3"
                android:startColor="#10000000"
                android:endColor="#00000000"/>
        </shape>
    </item>
</layer-list>