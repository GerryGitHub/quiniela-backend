# Example environment configuration. Copy to .env and fill in real values.
# Never commit .env — it is gitignored.

# List of allowed CORS origins (comma-separated). Required when credentials are enabled.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT signing secret (base64-encoded, min 256 bits / 32 bytes). Required.
JWT_SECRET=

# Database credentials
DB_USER=quiniela_user
DB_PASSWORD=quiniela_pass

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Quiniela <onboarding@resend.dev>
APP_BASE_URL=https://api.gjapps.com
