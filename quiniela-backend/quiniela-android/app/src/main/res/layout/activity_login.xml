<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Hero Section - 44% of screen -->
    <FrameLayout
        android:id="@+id/heroBackground"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fitsSystemWindows="true"
        app:layout_constraintHeight_percent="0.44"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Gradient Background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_login_new" />

        <!-- Geometric Pattern Overlay - Enhanced -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_pattern_refined" />

        <!-- Decorative diagonal lines -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_diagonals" />

        <!-- Editorial Layout: Left Text + Right Ball -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="24dp">

            <!-- Left Content -->
            <LinearLayout
                android:id="@+id/heroContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="100dp">

                <!-- Main Title - More prominent -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quiniela"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="-0.03"
                    android:shadowColor="#000000"
                    android:shadowDx="0"
                    android:shadowDy="3"
                    android:shadowRadius="6" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mundial 2026"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:alpha="0.95"
                    android:layout_marginTop="6dp" />

                <!-- Tagline -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Predice"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:alpha="0.85" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:alpha="0.5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compite"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:alpha="0.85" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:alpha="0.5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gana"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FF4D4D" />
            </LinearLayout>
            </LinearLayout>

            <!-- Hero Ball - 3x larger, center-right, protruding -->
            <ImageView
                android:id="@+id/ivHeroBall"
                android:layout_width="400dp"
                android:layout_height="400dp"
                android:src="@drawable/login_ball_hero"
                android:scaleType="fitCenter"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="-80dp"
                android:layout_marginTop="-60dp" />

        </RelativeLayout>

    </FrameLayout>

    <!-- Floating White Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/heroBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-40dp"
        android:layout_marginHorizontal="16dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Bienvenido!"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="4dp" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inicia sesión para continuar"
                    android:textSize="15sp"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="28dp" />

                <!-- Email Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxBackgroundColor="#F8FAFC"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeColor="#E2E8F0"
                    app:hintTextColor="#94A3B8"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="#6B7280">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Correo electrónico"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxBackgroundColor="#F8FAFC"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeColor="#E2E8F0"
                    app:hintTextColor="#94A3B8"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="#6B7280"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="#6B7280">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Contraseña"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Remember Me & Forgot Password -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <CheckBox
                        android:id="@+id/cbRemember"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recordarme"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:buttonTint="#0D5BFF" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Olvidaste tu contraseña?"
                        android:textSize="14sp"
                        android:textColor="#0D5BFF"
                        android:padding="4dp" />
                </LinearLayout>

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Iniciar Sesión"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#0D5BFF"
                    app:cornerRadius="16dp"
                    app:elevation="4dp"
                    app:rippleColor="#0847CC" />

                <!-- Biometric Button (hidden) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBiometric"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Iniciar con Huella/Rostro"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    app:icon="@android:drawable/ic_menu_view"
                    app:iconGravity="textStart"
                    app:strokeColor="#E2E8F0"
                    android:textColor="#6B7280" />

                <!-- Register Link -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿No tienes cuenta?"
                        android:textSize="14sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/btnRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Regístrate"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#0D5BFF"
                        android:padding="4dp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:visibility="gone"
                    android:indeterminateTint="#0D5BFF" />

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>